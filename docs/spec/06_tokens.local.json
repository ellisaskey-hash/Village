{
  "$comment": "Local design tokens. Structure mirrors Elevra's tokens.json so the same pipeline consumes it. Identity layer (colours, gradients, ambient, brand) is new; spacing/radius/type/motion/z inherited from Elevra with the WEAKNESSES fixes applied (standard Tailwind spacing & breakpoints, 44px chip).",
  "color": {
    "dark": {
      "bg": "#0D110D", "bgElevated": "#151B15", "bgSunken": "#090C09",
      "surface": "rgba(255,255,255,0.04)", "surfaceHover": "rgba(255,255,255,0.07)", "surfaceActive": "rgba(255,255,255,0.10)",
      "border": "rgba(255,255,255,0.08)", "borderStrong": "rgba(255,255,255,0.16)",
      "text": "#F5F7F2", "textMuted": "#98A394", "textFaint": "#6A755F", "textOnAccent": "#0C140C",
      "accent": "#7DD883", "accentWarm": "#F0B95A",
      "positive": "#7DD883", "warn": "#F0B95A", "danger": "#F07A72", "info": "#8AC6E8", "purple": "#C9A0E8",
      "chart1": "#7DD883", "chart2": "#F0B95A", "chart3": "#8AC6E8", "chart4": "#F07A72", "chart5": "#C9A0E8",
      "alertCommunity": "#8AC6E8", "alertVerified": "#F0B95A", "alertPlatform": "#F07A72"
    },
    "light": {
      "bg": "#F7F6F1", "bgElevated": "#FFFFFF", "bgSunken": "#EEEDE5",
      "surface": "rgba(28,34,26,0.03)", "surfaceHover": "rgba(28,34,26,0.05)", "surfaceActive": "rgba(28,34,26,0.08)",
      "border": "rgba(28,34,26,0.08)", "borderStrong": "rgba(28,34,26,0.14)",
      "text": "#1C221A", "textMuted": "#5C665A", "textFaint": "#77826F", "textOnAccent": "#FFFFFF",
      "accent": "#2F7A44", "accentWarm": "#B4791F",
      "positive": "#2F7A44", "warn": "#B4791F", "danger": "#CC4A44", "info": "#2F6FA8", "purple": "#7A55B8",
      "chart1": "#2F7A44", "chart2": "#B4791F", "chart3": "#2F6FA8", "chart4": "#CC4A44", "chart5": "#7A55B8",
      "alertCommunity": "#2F6FA8", "alertVerified": "#B4791F", "alertPlatform": "#CC4A44"
    }
  },
  "skin": {
    "village": { "$comment": "default — values above ARE the village skin" },
    "estate": { "$reserved": true, "dark": { "bg": "#0D0F12", "accent": "#7DD883" } },
    "retirement": { "$reserved": true, "defaults": { "data-density": "spacious", "data-contrast": "high" } }
  },
  "accentUserOverride": {
    "leaf":   { "dark": { "accent": "#7DD883" }, "light": { "accent": "#2F7A44" } },
    "honey":  { "dark": { "accent": "#F0B95A", "textOnAccent": "#141005" }, "light": { "accent": "#B4791F" } },
    "cobalt": { "dark": { "accent": "#7FA8FF" }, "light": { "accent": "#3D6FD0" } }
  },
  "gradient": {
    "dark": {
      "brand": "linear-gradient(135deg, #7DD883 0%, #F0B95A 100%)",
      "hairline": "linear-gradient(90deg, rgba(125,216,131,0.6), rgba(240,185,90,0.2))",
      "glowLeaf": "radial-gradient(circle, rgba(125,216,131,0.08) 0%, transparent 70%)",
      "glowHoney": "radial-gradient(circle, rgba(240,185,90,0.07) 0%, transparent 70%)"
    },
    "light": {
      "brand": "linear-gradient(135deg, #57B36E 0%, #E0A94E 100%)",
      "hairline": "linear-gradient(90deg, rgba(47,122,68,0.55), rgba(180,121,31,0.18))"
    }
  },
  "ambient": {
    "$comment": "the hearth signature",
    "dark": {
      "1": "radial-gradient(60% 40% at 15% 8%, rgba(240,185,90,0.09), transparent 70%)",
      "2": "radial-gradient(50% 35% at 85% 92%, rgba(125,216,131,0.06), transparent 70%)"
    },
    "light": {
      "1": "radial-gradient(75% 55% at 8% 6%, rgba(240,185,90,0.18), transparent 72%)",
      "2": "radial-gradient(70% 50% at 92% 12%, rgba(125,216,131,0.14), transparent 72%)",
      "3": "radial-gradient(85% 60% at 50% 96%, rgba(224,169,78,0.16), transparent 75%)"
    }
  },
  "glass": {
    "dark": {
      "panelBg": "rgba(13,17,13,0.80)", "fadeFrom": "rgba(13,17,13,1)", "fadeMid": "rgba(13,17,13,0.55)",
      "backdrop": "rgba(13,17,13,0.65)",
      "rowBg": "rgba(255,255,255,0.04)", "rowBgHover": "rgba(255,255,255,0.08)", "rowBorder": "rgba(255,255,255,0.08)",
      "scrollThumb": "rgba(125,216,131,0.28)", "scrollThumbHover": "rgba(125,216,131,0.55)", "scrollThumbActive": "rgba(125,216,131,0.75)"
    },
    "light": {
      "panelBg": "#FFFFFF", "fadeFrom": "#FFFFFF", "fadeMid": "rgba(255,255,255,0.55)",
      "backdrop": "rgba(28,34,26,0.28)",
      "rowBg": "rgba(28,34,26,0.03)", "rowBgHover": "rgba(28,34,26,0.06)", "rowBorder": "rgba(28,34,26,0.08)",
      "scrollThumb": "rgba(47,122,68,0.32)", "scrollThumbHover": "rgba(47,122,68,0.55)", "scrollThumbActive": "rgba(47,122,68,0.75)"
    }
  },
  "focus": {
    "dark": { "ring": "rgba(125,216,131,0.28)", "ringSoft": "rgba(125,216,131,0.20)" },
    "light": { "ring": "rgba(47,122,68,0.28)", "ringSoft": "rgba(47,122,68,0.20)" }
  },
  "shadow": {
    "dark": {
      "card": "0 2px 12px rgba(0,0,0,0.35)", "raised": "0 8px 28px rgba(0,0,0,0.45)",
      "glowAccent": "0 0 24px rgba(125,216,131,0.22)", "glowWarm": "0 0 24px rgba(240,185,90,0.20)"
    },
    "light": {
      "card": "0 1px 2px rgba(28,34,26,0.04), 0 8px 24px rgba(28,34,26,0.06)",
      "raised": "0 4px 16px rgba(28,34,26,0.06), 0 24px 48px rgba(28,34,26,0.10)",
      "glowAccent": "0 0 24px rgba(47,122,68,0.16)"
    }
  },
  "spacing": {
    "$comment": "STANDARD Tailwind scale (Elevra fix #1/#5). Named extras only.",
    "screenX": 20, "sectionGap": 28, "cardPad": 16, "tabBarHeight": 64
  },
  "radius": { "sm": 8, "md": 12, "lg": 16, "xl": 20, "sheet": 24, "pill": 999 },
  "type": {
    "$comment": "inherited from Elevra verbatim",
    "display": { "sizePx": 34, "lineHeight": 1.15, "letterSpacing": "-0.02em", "weight": 700 },
    "h1": { "sizePx": 26, "lineHeight": 1.2, "letterSpacing": "-0.02em", "weight": 700 },
    "h2": { "sizePx": 21, "lineHeight": 1.25, "letterSpacing": "-0.01em", "weight": 600 },
    "h3": { "sizePx": 17, "lineHeight": 1.3, "letterSpacing": "-0.01em", "weight": 600 },
    "body": { "sizePx": 15, "lineHeight": 1.55, "weight": 400 },
    "input": { "sizePx": 16, "lineHeight": 1.5, "weight": 400, "$note": "iOS zoom floor" },
    "small": { "sizePx": 13, "lineHeight": 1.45, "weight": 400 },
    "micro": { "sizePx": 11, "lineHeight": 1.35, "letterSpacing": "0.02em", "weight": 500 },
    "eyebrow": { "sizePx": 11, "lineHeight": 1.2, "letterSpacing": "0.12em", "weight": 600, "$note": "UPPERCASE" }
  },
  "font": {
    "display": "'Inter Tight', 'Inter', system-ui, sans-serif",
    "body": "'Inter', system-ui, sans-serif",
    "dyslexiaSwap": "'Atkinson Hyperlegible', 'Inter', system-ui, sans-serif"
  },
  "density": { "compact": { "rootFontSize": "15px" }, "regular": { "rootFontSize": "16px" }, "spacious": { "rootFontSize": "17px" } },
  "z": { "base": 0, "raised": 10, "header": 20, "tabBar": 30, "popover": 35, "sheet": 40, "popoverElevated": 45, "modal": 50, "toast": 60, "installCoach": 70 },
  "breakpoint": { "$comment": "STANDARD Tailwind (Elevra fix #8)", "sm": 640, "md": 768, "lg": 1024, "xl": 1280 },
  "motion": {
    "$comment": "inherited from Elevra verbatim — the feel being cloned",
    "durationMs": { "instant": 120, "fast": 200, "base": 280, "slow": 360, "drawn": 700 },
    "spring": {
      "snappy": { "type": "spring", "stiffness": 420, "damping": 32 },
      "sheet": { "type": "spring", "stiffness": 320, "damping": 34 },
      "gentle": { "type": "spring", "stiffness": 220, "damping": 28 }
    },
    "easing": { "easeOut": [0.16, 1, 0.3, 1], "easeInOut": [0.65, 0, 0.35, 1] },
    "stagger": { "children": 0.05, "delay": 0.04 }
  },
  "keyframe": {
    "breath": {
      "duration": "2.4s", "easing": "ease-in-out", "iteration": "infinite",
      "keyframes": {
        "0%,100%": "box-shadow: 0 0 0 0 rgba(240,185,90,0.15), 0 0 6px 0 rgba(240,185,90,0.25)",
        "50%": "box-shadow: 0 0 0 6px rgba(240,185,90,0.05), 0 0 18px 2px rgba(240,185,90,0.4)"
      }
    }
  },
  "statusColor": {
    "requestOpen": "info", "requestAnswered": "warn", "requestFulfilled": "positive",
    "listingActive": "positive", "listingReserved": "warn", "listingExpired": "textFaint"
  },
  "brand": { "name": "Local", "$comment": "single rename point — consumed by manifest, wordmark, copy interpolation" }
}
