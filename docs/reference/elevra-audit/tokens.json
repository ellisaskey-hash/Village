    "dark": {
      "card":        "0 2px 12px rgba(0,0,0,0.35)",
      "raised":      "0 8px 28px rgba(0,0,0,0.45)",
      "glowAccent":  "0 0 24px rgba(56,225,255,0.25)",
      "glowLime":    "0 0 24px rgba(168,255,96,0.22)"
    },
    "light": {
      "card":        "0 1px 2px rgba(15,26,46,0.04), 0 8px 24px rgba(15,26,46,0.06)",
      "raised":      "0 4px 16px rgba(15,26,46,0.06), 0 24px 48px rgba(15,26,46,0.10)",
      "glowAccent":  "0 0 24px rgba(61,125,247,0.18)",
      "glowLime":    "0 0 24px rgba(61,156,95,0.18)"
    }
  },
  "spacing": {
    "base": "4pt",
    "0":  0,  "1":  4,  "2":  8,  "3": 12,
    "4": 16,  "5": 20,  "6": 24,  "7": 32,
    "8": 40,  "9": 48,  "10": 64, "11": 80,
    "screenX":       20,
    "sectionGap":    28,
    "cardPad":       16,
    "tabBarHeight":  64,
    "$note": "Tailwind h-8/h-10/h-11 resolve to 40/64/80 here, NOT the framework defaults 32/40/44. Consumers use arbitrary values (h-[32px]) for canonical rendered sizes."
  },
  "radius": { "sm": 8, "md": 12, "lg": 16, "xl": 20, "sheet": 24, "pill": 999 },
  "type": {
    "display": { "sizePx": 34, "lineHeight": 1.15, "letterSpacing": "-0.02em", "weight": 700 },
    "h1":      { "sizePx": 26, "lineHeight": 1.2,  "letterSpacing": "-0.02em", "weight": 700 },
    "h2":      { "sizePx": 21, "lineHeight": 1.25, "letterSpacing": "-0.01em", "weight": 600 },
    "h3":      { "sizePx": 17, "lineHeight": 1.3,  "letterSpacing": "-0.01em", "weight": 600 },
    "body":    { "sizePx": 15, "lineHeight": 1.55, "letterSpacing": "0",       "weight": 400 },
    "input":   { "sizePx": 16, "lineHeight": 1.5,  "letterSpacing": "0",       "weight": 400, "$note": "iOS zoom floor" },
    "small":   { "sizePx": 13, "lineHeight": 1.45, "letterSpacing": "0",       "weight": 400 },
    "micro":   { "sizePx": 11, "lineHeight": 1.35, "letterSpacing": "0.02em",  "weight": 500 },
    "eyebrow": { "sizePx": 11, "lineHeight": 1.2,  "letterSpacing": "0.12em",  "weight": 600, "$note": "UPPERCASE" }
  },
  "font": {
    "display":       "'Inter Tight', 'Inter', system-ui, sans-serif",
    "body":          "'Inter', system-ui, sans-serif",
    "handwriting":   "'Caveat', 'Marker Felt', 'Comic Sans MS', cursive",
    "dyslexiaSwap":  "'Atkinson Hyperlegible', 'Inter', system-ui, sans-serif"
  },
  "density": {
    "compact":  { "rootFontSize": "15px" },
    "regular":  { "rootFontSize": "16px" },
    "spacious": { "rootFontSize": "17px" }
  },
  "z": {
    "base":            0,
    "raised":         10,
    "header":         20,
    "tabBar":         30,
    "popover":        35,
    "sheet":          40,
    "popoverElevated":45,
    "modal":          50,
    "toast":          60,
    "installCoach":   70
  },
  "breakpoint": {
    "sm": 360,
    "md": 600,
    "lg": 900,
    "xl": 1200,
    "$note": "NOT Tailwind defaults. Consumers assume these."
  },
  "motion": {
    "durationMs": {
      "instant": 120,
      "fast":    200,
      "base":    280,
      "slow":    360,
      "drawn":   700
    },
    "spring": {
      "snappy":  { "type": "spring", "stiffness": 420, "damping": 32, "$use": "buttons, chips, small UI" },
      "sheet":   { "type": "spring", "stiffness": 320, "damping": 34, "$use": "sheets, drawers" },
      "gentle":  { "type": "spring", "stiffness": 220, "damping": 28, "$use": "cards settling, reorder" }
    },
    "easing": {
      "easeOut":   [0.16, 1,   0.3,  1],
      "easeInOut": [0.65, 0,   0.35, 1]
    },
    "stagger": {
      "children": 0.05,
      "delay":    0.04
    }
  },
  "keyframe": {
    "breath": {
      "duration":  "2.4s",
      "easing":    "ease-in-out",
      "iteration": "infinite",
      "keyframes": {
        "0%,100%": "box-shadow: 0 0 0 0 rgba(174,240,119,0.15), 0 0 6px 0 rgba(174,240,119,0.25)",
        "50%":     "box-shadow: 0 0 0 6px rgba(174,240,119,0.05), 0 0 18px 2px rgba(174,240,119,0.4)"
      }
    },
    "voice-playhead": {
      "duration":  "0.5s",
      "easing":    "ease-in-out",
      "iteration": "infinite",
      "keyframes": {
        "0%,100%": "transform: scaleY(1)",
        "50%":     "transform: scaleY(1.4)"
      }
    }
  },
  "statusColor": {
    "onTrack": "positive",
    "quiet":   "warn",
    "atRisk":  "danger"
  }
}
