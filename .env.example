# Local — environment variables (M0 uses none at runtime; listed for later milestones).
# Only VITE_-prefixed vars are exposed to the client bundle. Everything else is server-only.

# Client (public) — safe to ship in the bundle
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SENTRY_DSN=
VITE_TURNSTILE_SITE_KEY=

# Server only (Vercel functions) — never VITE_-prefixed, never in the client bundle
SUPABASE_SERVICE_ROLE_KEY=
ANTHROPIC_API_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
SENTRY_DSN=
COMPANIES_HOUSE_API_KEY=
